{
    "github": {//settings used to generate your github resume
        "user": "megawac", //if falsy we'll guess

        "include repos": true,
        "include pulls": true, //attempt to find your pull requests (requires a lot of requests with current github api)
        "include unmerged pulls": false,
        
        //Sorting weights. The weights are multiplied by the corresponding repo value in order to sort your repos
        "sort repo weights": {
            "stars": 1,
            "watchers": 1,
            "commits": 0,
            "activity": 0 //days since last commit
        },
        "sort pull weights": {
            "stars": 1,
            "watchers": 1,
            "commits": 10,
            "activity": 0
        }, //How to sort your pull requests (latest 100). Valid options are ["stars", "commits", "activity"]

        "max organizations": 10,
        "max contributions": 6,
        "max repos": 6,

        "exclude repos": ["cdnjs", "jsdelivr", "megawac.github.io"]//repos to exclude by repo name
    },

    //most of these are optional beside some of the obvious
    "name": "Graeme J. Yeates",
    "title": "Web Developer/GIS Specialist",
    "phone": "(647) 215-7372",
    "contact": "gjyeates@uwaterloo.ca",
    "portfolio": "www.github.com/megawac",
    
}
